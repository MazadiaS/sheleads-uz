# Copy to .env.local and fill with your Supabase project values.
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Donations (set whichever you have; unset providers are hidden) ---
# Payme merchant (checkout.paycom.uz). Amount sent in tiyin automatically.
VITE_PAYME_MERCHANT_ID=
VITE_PAYME_ACCOUNT_FIELD=order_id
# Click merchant (my.click.uz). Needs both IDs.
VITE_CLICK_MERCHANT_ID=
VITE_CLICK_SERVICE_ID=

# Bank-transfer fallback (shown if account is set)
VITE_BANK_BENEFICIARY=
VITE_BANK_ACCOUNT=
VITE_BANK_NAME=
VITE_BANK_MFO=
VITE_BANK_INN=

# --- Analytics (Plausible) — leave blank to disable; nothing loads until set ---
VITE_PLAUSIBLE_DOMAIN=
# Only if you self-host Plausible (defaults to https://plausible.io)
VITE_PLAUSIBLE_HOST=
